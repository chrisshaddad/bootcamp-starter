# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Auth.js host configuration
AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:3000

# Keycloak — server-side only (never expose to client)
KEYCLOAK_BASE=https://your-keycloak-host/keycloak
KEYCLOAK_REALM=your-realm
OIDC_ISSUER=https://your-keycloak-host/keycloak/realms/your-realm
OAUTH_CLIENT=your-client-id
OAUTH_SECRET=your-client-secret

# NestJS backend — server-side only, used by BFF/RSC. NEVER prefix with NEXT_PUBLIC_
API_URL=http://localhost:4000

# Stripe publishable key — safe to expose to client
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
