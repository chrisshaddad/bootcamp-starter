{
  "extends": "../../packages/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": "./",
    "paths": {
      "@/components/*": ["components/*"],
      "@/utils/*": ["lib/utils/*"],
      "@/ui/*": ["components/ui/*"],
      "@/lib/*": ["lib/*"],
      "@/hooks/*": ["hooks/*"],
      "@repo/contracts": ["../../packages/contracts/dist/index"],
      "@repo/contracts/*": ["../../packages/contracts/dist/*"],
      "@repo/db": ["../../packages/database/dist/index"],
      "@repo/db/*": ["../../packages/database/dist/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
