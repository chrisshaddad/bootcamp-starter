generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrgStatus {
  PENDING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Organization {
  id               String        @id @default(cuid())
  name             String
  status           OrgStatus     @default(PENDING)
  stripeCustomerId String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  subscription     Subscription?
  payments         Payment[]
  events           Event[]
  buildings        Building[]
}

model Subscription {
  id                   String       @id @default(cuid())
  orgId                String       @unique
  stripeSubscriptionId String?      @unique
  stripeCustomerId     String?
  status               String
  priceId              String?
  planKey              String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  org                  Organization @relation(fields: [orgId], references: [id])
}

model Payment {
  id              String        @id @default(cuid())
  orgId           String
  stripeInvoiceId String?       @unique
  stripeSessionId String?
  amount          Decimal       @db.Decimal(12, 2)
  currency        String
  status          PaymentStatus @default(PENDING)
  paidAt          DateTime?
  rawPayload      Json
  createdAt       DateTime      @default(now())
  org             Organization  @relation(fields: [orgId], references: [id])
}

model Event {
  id         String       @id @default(cuid())
  orgId      String
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  metadata   Json         @default("{}")
  createdAt  DateTime     @default(now())
  org        Organization @relation(fields: [orgId], references: [id])
}

model Building {
  id          String               @id @default(cuid())
  orgId       String
  name        String
  address     String?
  code        String?
  notes       String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  org         Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignments BuildingAssignment[]

  @@index([orgId])
}

model BuildingAssignment {
  id         String   @id @default(cuid())
  userId     String
  orgId      String
  buildingId String
  createdAt  DateTime @default(now())
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([userId, buildingId])
  @@index([orgId])
  @@index([userId])
}
