generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "private"]
}

enum AccountType {
  DEVELOPER
  HIRING
  SUPER_ADMIN

  @@schema("public")
}

enum OrganizationType {
  COMPANY
  AGENCY
  INDIVIDUAL
  FREELANCE_CLIENT

  @@schema("public")
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@schema("public")
}

enum ProjectRoleKey {
  OWNER
  EDITOR
  CONTRIBUTOR

  @@schema("public")
}

enum VerificationStatus {
  PENDING
  VERIFIED
  UNVERIFIED

  @@schema("public")
}

enum VerificationSource {
  GITHUB_CONTRIBUTOR
  GITHUB_COLLABORATOR
  MANUAL_INVITE

  @@schema("public")
}

enum TechnologyCategory {
  LANGUAGE
  FRAMEWORK
  LIBRARY
  DATABASE
  CLOUD
  DEVOPS
  TOOL
  OTHER

  @@schema("public")
}

enum ProjectTechnologySource {
  SCANNER
  MANUAL
  BOTH

  @@schema("public")
}

enum MediaType {
  IMAGE
  VIDEO
  GIF
  ARCHITECTURE_DIAGRAM

  @@schema("public")
}

enum RepositoryVisibility {
  PUBLIC
  PRIVATE

  @@schema("public")
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  accountType  AccountType
  isConfirmed  Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  developerProfile DeveloperProfile?
  hiringProfile    HiringProfile?

  sessions   Session[]
  magicLinks MagicLink[]

  createdProjects     Project[]           @relation("ProjectCreator")
  addedMembers        ProjectMember[]     @relation("MemberAddedBy")
  projectMemberships  ProjectMember[]     @relation("UserProjectMemberships")
  uploadedMedia       ProjectMedia[]
  savedProjects       SavedProject[]
  addedTechnologies   ProjectTechnology[] @relation("ProjectTechAddedBy")

  @@index([accountType])
  @@schema("public")
}

model DeveloperProfile {
  id String @id @default(uuid())
  userId String @unique

  publicSlug  String  @unique
  displayName String
  headline    String?
  bio         String? @db.Text
  location    String?

  profilePictureUrl  String?
  linkedinUrl        String?
  personalWebsiteUrl String?

  githubUserId      BigInt?   @unique
  githubUsername    String?   @unique
  githubConnectedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("public")
}

model HiringProfile {
  id     String @id @default(uuid())
  userId String @unique

  organizationName String
  organizationType OrganizationType
  jobTitle         String?

  linkedinUrl            String?
  organizationWebsiteUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationName])
  @@index([organizationType])
  @@schema("public")
}

model Repository {
  id String @id @default(uuid())

  githubRepoId BigInt @unique
  fullName     String @unique
  ownerLogin   String
  repoName     String
  htmlUrl      String @unique

  defaultBranch String?
  visibility    RepositoryVisibility @default(PUBLIC)

  lastPushedAt DateTime?
  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project?

  @@index([ownerLogin])
  @@index([repoName])
  @@schema("public")
}

model Project {
  id String @id @default(uuid())

  repositoryId    String @unique
  createdByUserId String

  title String
  slug  String @unique

  shortDescription String? @db.Text
  fullDescription  String? @db.Text

  deploymentUrl String?

  status ProjectStatus @default(DRAFT)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  createdBy  User       @relation("ProjectCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  members      ProjectMember[]
  technologies ProjectTechnology[]
  media        ProjectMedia[]
  savedByUsers SavedProject[]

  @@index([status])
  @@index([createdByUserId])
  @@schema("public")
}

model ProjectMember {
  id String @id @default(uuid())

  projectId      String
  userId         String?
  githubUsername String?

  role ProjectRoleKey

  contributionRoleLabel String?
  contributionSummary   String? @db.Text
  githubPermission      String?

  verificationStatus VerificationStatus  @default(PENDING)
  verificationSource VerificationSource?
  verifiedAt         DateTime?

  addedByUserId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation("UserProjectMemberships", fields: [userId], references: [id], onDelete: SetNull)
  addedBy User?   @relation("MemberAddedBy", fields: [addedByUserId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([userId])
  @@index([githubUsername])
  @@index([verificationStatus])
  @@index([addedByUserId])
  @@schema("public")
}

model Technology {
  id       String             @id @default(uuid())
  name     String
  slug     String             @unique
  category TechnologyCategory

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects ProjectTechnology[]

  @@index([category])
  @@schema("public")
}

model ProjectTechnology {
  id String @id @default(uuid())

  projectId    String
  technologyId String

  source ProjectTechnologySource

  evidence   String?   @db.Text
  detectedAt DateTime?

  addedByUserId String?
  isPrimary     Boolean @default(false)
  sortOrder     Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  technology Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)
  addedBy    User?      @relation("ProjectTechAddedBy", fields: [addedByUserId], references: [id], onDelete: SetNull)

  @@unique([projectId, technologyId])
  @@index([projectId])
  @@index([technologyId])
  @@index([isPrimary])
  @@index([addedByUserId])
  @@schema("public")
}

model ProjectMedia {
  id String @id @default(uuid())

  projectId        String
  uploadedByUserId String

  mediaType MediaType

  storageKey String
  publicUrl  String

  caption   String? @db.Text
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedByUserId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([uploadedByUserId])
  @@schema("public")
}

model SavedProject {
  id String @id @default(uuid())

  savedByUserId String
  projectId     String

  note String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  savedBy User    @relation(fields: [savedByUserId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([savedByUserId, projectId])
  @@index([savedByUserId])
  @@index([projectId])
  @@schema("public")
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("private")
}

model MagicLink {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@schema("private")
} 